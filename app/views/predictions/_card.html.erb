<%
  leader = predictions.first
  podium_by_driver = race.predictions.of_type("podium").index_by(&:driver_id)
  entries_by_driver = race.race_entries.index_by(&:driver_id)
%>
<section id="race_<%= race.id %>_prediction_card"
         class="overflow-hidden rounded border border-hairline bg-surface"
         data-controller="prediction">
  <header class="flex flex-wrap items-start justify-between gap-3 border-b border-hairline px-5 py-4">
    <div>
      <h2 class="text-sm font-bold uppercase tracking-wide">Predicted result</h2>
      <p class="mt-1 text-sm text-ink-muted">
        Chance of winning, for every car on the grid.
      </p>
    </div>

    <% if predictions.any? %>
      <p class="text-right text-xs text-ink-muted">
        <%= leader.model_version %> · <%= time_ago_in_words(leader.updated_at) %> ago
      </p>
    <% end %>
  </header>

  <% if predictions.empty? %>
    <div class="px-5 py-12 text-center">
      <p class="text-ink-2">No prediction yet.</p>
      <p class="mx-auto mt-2 max-w-md text-sm text-ink-muted">
        Generating one sends the starting grid and each driver's form rating to the
        model, then fills this table in. It takes about a second.
      </p>
      <% if user_signed_in? %>
        <div class="mt-5">
          <%= button_to "Generate prediction", race_prediction_path(race),
                class: "rounded bg-accent px-4 py-2 text-sm font-semibold uppercase tracking-wide text-white hover:brightness-110" %>
        </div>
      <% end %>
    </div>
  <% else %>
    <!-- Hero: the one number this card exists to deliver. -->
    <div class="flex flex-wrap items-center gap-5 border-b border-hairline bg-surface-2/40 px-5 py-5">
      <%= render "drivers/avatar", driver: leader.driver, size: "h-16 w-16", text_size: "text-base" %>

      <div class="min-w-0">
        <p class="text-xs uppercase tracking-wide text-ink-muted">Most likely winner</p>
        <p class="mt-0.5 truncate text-xl font-bold"><%= leader.driver.full_name %></p>
        <p class="mt-0.5 text-sm text-ink-muted">
          <%= leader.driver.constructor.short_name %>
          · starts P<%= entries_by_driver[leader.driver_id]&.grid_position || "?" %>
        </p>
      </div>

      <p class="ml-auto text-right">
        <span class="block text-4xl font-bold leading-none text-accent"><%= leader.percentage %>%</span>
        <span class="mt-1 block text-xs uppercase tracking-wide text-ink-muted">to win</span>
      </p>
    </div>

    <!-- Every value is present as text, so this table is also the accessible view. -->
    <div class="overflow-x-auto">
      <table class="w-full min-w-136 text-sm">
        <thead>
          <tr class="border-b border-hairline text-xs uppercase tracking-wide text-ink-muted">
            <th scope="col" class="w-10 px-3 py-2 text-left font-medium">Pos</th>
            <th scope="col" class="px-3 py-2 text-left font-medium">Driver</th>
            <th scope="col" class="w-14 px-3 py-2 text-right font-medium">Grid</th>
            <th scope="col" class="w-40 px-3 py-2 text-left font-medium">Win chance</th>
            <th scope="col" class="w-20 px-3 py-2 text-right font-medium">Podium</th>
          </tr>
        </thead>

        <tbody>
          <% predictions.each_with_index do |prediction, index| %>
            <%
              driver = prediction.driver
              entry = entries_by_driver[driver.id]
              podium = podium_by_driver[driver.id]
              leading = index.zero?
            %>
            <tr class="border-b border-hairline last:border-0 <%= "bg-surface-2/40" if leading %>">
              <td class="px-3 py-2 text-center font-semibold tabular-nums"><%= index + 1 %></td>

              <td class="px-3 py-2">
                <div class="flex items-center gap-2.5">
                  <%= render "constructors/mark", constructor: driver.constructor %>
                  <%= render "drivers/avatar", driver: driver, size: "h-8 w-8", text_size: "text-[10px]" %>
                  <span class="min-w-0">
                    <span class="block truncate <%= leading ? "font-semibold" : "font-medium" %>">
                      <%= driver.full_name %>
                    </span>
                    <span class="block truncate text-xs text-ink-muted">
                      <%= driver.constructor.short_name %>
                    </span>
                  </span>
                </div>
              </td>

              <td class="px-3 py-2 text-right tabular-nums text-ink-muted">
                <%= entry&.grid_position || "—" %>
              </td>

              <td class="px-3 py-2">
                <div class="flex items-center gap-2">
                  <!-- min-width keeps a long-shot's bar visible instead of an
                       empty track, which reads as missing data. -->
                  <span class="h-1.5 flex-1 overflow-hidden rounded-l-sm bg-surface-2">
                    <span class="block h-full min-w-0.5 rounded-r-sm transition-[width] duration-700 ease-out <%= leading ? "bg-accent" : "bg-deemph" %>"
                          style="width: <%= [ prediction.percentage, 100 ].min %>%"
                          data-prediction-target="bar"></span>
                  </span>
                  <span class="w-12 shrink-0 text-right tabular-nums <%= leading ? "font-semibold" : "text-ink-2" %>">
                    <%= prediction.display_percentage %>
                  </span>
                </div>
              </td>

              <td class="px-3 py-2 text-right tabular-nums text-ink-muted">
                <%= podium ? podium.display_percentage : "—" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <footer class="space-y-3 border-t border-hairline px-5 py-4">
      <%# CC BY / BY-SA require visible attribution, so the photographers are
          listed here rather than only in an image tooltip. %>
      <% credited = predictions.map(&:driver).select { |d| d.image_attribution.present? } %>
      <% if credited.any? %>
        <details>
          <summary class="cursor-pointer text-sm text-ink-2 hover:text-ink">
            Photo credits
          </summary>
          <ul class="mt-2 space-y-0.5 text-xs text-ink-muted">
            <% credited.each do |driver| %>
              <li>
                <%= driver.full_name %> —
                <% if driver.image_source_url.present? %>
                  <%= link_to driver.image_attribution, driver.image_source_url,
                        class: "underline hover:text-ink-2", rel: "noopener" %>
                <% else %>
                  <%= driver.image_attribution %>
                <% end %>
                <%= "(#{driver.image_license})" if driver.image_license.present? %>
              </li>
            <% end %>
          </ul>
        </details>
      <% end %>

      <details class="group">
        <summary class="cursor-pointer text-sm text-ink-2 hover:text-ink">
          How is this calculated?
        </summary>
        <div class="mt-3 space-y-2 text-sm text-ink-muted">
          <p>
            A logistic regression trained on 101 real races (2022&ndash;2026) scores
            each car on five inputs: starting slot, form rating, where that slot sits in
            the field, the pace gap to the quickest car, and whether it starts on the front row.
          </p>
          <p>
            Scores are then rescaled so win chances across the field add up to 100%,
            and podium chances add up to 300% &mdash; three places available.
          </p>
          <p>
            <strong class="text-ink-2">Starting position dominates.</strong> A car
            starting at the front is favoured because that is what the history says;
            the model knows nothing about this weekend's weather, upgrades, or reliability.
          </p>
        </div>
      </details>
    </footer>
  <% end %>
</section>
