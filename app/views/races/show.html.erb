<% content_for :title, @race.to_s %>

<%= turbo_stream_from @race.prediction_stream %>

<%= link_to races_path, class: "text-sm text-ink-muted hover:text-ink" do %>
  &larr; <%= @race.season %> race calendar
<% end %>

<!-- Race hub header -->
<section class="mt-4 overflow-hidden rounded border border-hairline bg-surface">
  <div class="flex flex-wrap items-start justify-between gap-4 border-l-4 border-accent px-5 py-5">
    <div>
      <p class="text-xs font-medium uppercase tracking-wide text-ink-muted">
        Round <%= @race.round %> · <%= @race.circuit.country %>
      </p>
      <h1 class="mt-1 text-3xl font-bold"><%= @race.name %></h1>
      <p class="mt-1 text-ink-2"><%= @race.circuit.name %></p>
      <p class="mt-0.5 text-sm text-ink-muted">
        <%= @race.starts_at&.strftime("%A %d %B %Y, %H:%M") || "Time to be confirmed" %>
      </p>
    </div>

    <% if @race.circuit.outline? %>
      <div class="text-ink-2">
        <%= render "circuits/map", circuit: @race.circuit, classes: "h-28 w-56" %>
      </div>
    <% end %>

    <div class="flex flex-col items-end gap-3">
      <%= render "races/status_pill", status: @race.status %>

      <% if user_signed_in? %>
        <%= button_to "Generate prediction", race_prediction_path(@race),
              class: "rounded bg-accent px-4 py-2 text-sm font-semibold uppercase tracking-wide text-white hover:brightness-110" %>
      <% else %>
        <%= link_to "Sign in to generate a prediction", new_user_session_path,
              class: "rounded border border-hairline px-4 py-2 text-sm text-ink-2 hover:text-ink" %>
      <% end %>
    </div>
  </div>

  <!-- Only facts we actually hold: the importer fills circuit name and country,
       lap count and length aren't in the FastF1 schedule. -->
  <%
    facts = [
      [ "Round", "#{@race.round} of 22" ],
      [ "Cars", @entries.size ],
      ([ "Laps", @race.circuit.laps ] if @race.circuit.laps),
      [ "Grid", @race.real_grid? ? "Confirmed" : "Estimated" ]
    ].compact
  %>
  <%# Static class list: Tailwind scans source text, so an interpolated
      grid-cols-#{n} would never be generated. %>
  <% columns = { 3 => "sm:grid-cols-3", 4 => "sm:grid-cols-4" }.fetch(facts.size, "sm:grid-cols-4") %>
  <dl class="grid grid-cols-2 divide-x divide-hairline border-t border-hairline <%= columns %>">
    <% facts.each do |label, value| %>
      <div class="px-5 py-3">
        <dt class="text-xs uppercase tracking-wide text-ink-muted"><%= label %></dt>
        <dd class="mt-0.5 text-lg font-semibold"><%= value %></dd>
      </div>
    <% end %>
  </dl>
</section>

<%= render "shared/data_notice" %>

<div class="mt-6 grid gap-6 lg:grid-cols-3">
  <div class="space-y-6 lg:col-span-2">
    <%# Once the race has run, the actual result leads — the prediction becomes
        a claim to check rather than the headline. %>
    <% if @race.result? %>
      <%= render "races/result", race: @race %>
    <% end %>

    <%= render "predictions/card", race: @race, predictions: @predictions %>
  </div>

  <section class="self-start overflow-hidden rounded border border-hairline bg-surface lg:sticky lg:top-6">
    <header class="border-b border-hairline px-5 py-4">
      <h2 class="text-sm font-bold uppercase tracking-wide">Starting grid</h2>
      <p class="mt-1 text-sm text-ink-muted">
        <%= @race.real_grid? ? "From qualifying." : "Estimated from form." %>
        Rating is 0&ndash;100.
      </p>
    </header>

    <ol>
      <% @entries.each do |entry| %>
        <li class="flex items-center gap-2.5 border-b border-hairline px-5 py-2 text-sm last:border-0">
          <span class="w-5 shrink-0 text-right font-semibold tabular-nums text-ink-muted">
            <%= entry.grid_position %>
          </span>
          <%= render "constructors/mark", constructor: entry.constructor %>
          <%= render "drivers/avatar", driver: entry.driver, size: "h-7 w-7", text_size: "text-[10px]" %>
          <span class="min-w-0 flex-1">
            <span class="block truncate font-medium"><%= entry.driver.full_name %></span>
            <span class="block truncate text-xs text-ink-muted"><%= entry.constructor.short_name %></span>
          </span>
          <span class="shrink-0 tabular-nums text-ink-muted">
            <%= entry.pace_rating&.to_f&.round %>
          </span>
        </li>
      <% end %>
    </ol>
  </section>
</div>
